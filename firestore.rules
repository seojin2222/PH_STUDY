rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 로그인(Firebase Auth)한 직원만 읽고 쓸 수 있음.
    match /students/{docId} {
      allow read, write: if request.auth != null;
    }
    match /records/{docId} {
      allow read, write: if request.auth != null;
    }
    match /dailySummaries/{docId} {
      allow read, write: if request.auth != null;
    }
    match /settings/{docId} {
      allow read, write: if request.auth != null;
    }
  }
}
